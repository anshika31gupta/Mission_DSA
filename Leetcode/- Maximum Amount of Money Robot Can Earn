class Solution {
public:
    int maximumAmount(vector<vector<int>>& coins) {
        int m = coins.size(), n = coins[0].size();
        
        vector<vector<vector<int>>> dp(m, vector<vector<int>>(n, vector<int>(3, INT_MIN)));
        
        // Base case
        dp[0][0][0] = coins[0][0];
        if (coins[0][0] < 0) dp[0][0][1] = 0;
        
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                if (i == 0 && j == 0) continue;
                
                for (int k = 0; k <= 2; k++) {
                    int val = coins[i][j];
                    
                    // FROM TOP
                    if (i > 0) {
                        // no neutralize
                        if (dp[i-1][j][k] != INT_MIN) {
                            dp[i][j][k] = max(dp[i][j][k], dp[i-1][j][k] + val);
                        }
                        
                        // neutralize (only if val < 0)
                        if (val < 0 && k > 0 && dp[i-1][j][k-1] != INT_MIN) {
                            dp[i][j][k] = max(dp[i][j][k], dp[i-1][j][k-1]);
                        }
                    }
                    
                    // FROM LEFT
                    if (j > 0) {
                        // no neutralize
                        if (dp[i][j-1][k] != INT_MIN) {
                            dp[i][j][k] = max(dp[i][j][k], dp[i][j-1][k] + val);
                        }
                        
                        // neutralize
                        if (val < 0 && k > 0 && dp[i][j-1][k-1] != INT_MIN) {
                            dp[i][j][k] = max(dp[i][j][k], dp[i][j-1][k-1]);
                        }
                    }
                }
            }
        }
        
        return max({dp[m-1][n-1][0], dp[m-1][n-1][1], dp[m-1][n-1][2]});
    }
};

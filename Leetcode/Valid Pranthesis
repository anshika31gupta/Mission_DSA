class Solution {
public:
bool helper(string s){
    stack<char>st;
    int n=s.length();
    if(n==1) return false;
    for(int i=0;i<n;i++){
        if(s[i]=='(' || s[i]=='[' || s[i]=='{'){
            st.push(s[i]);
        }
        else 
        { 
            if(st.size() ==0) return false;
            char j =st.top();
             st.pop();
            if(s[i] ==')' && j!='(' ||s[i]==']' && j!='[' || s[i]=='}' && j!='{')
                return false;
               
       }
    }
   if(st.empty())
       return true;
        
     return false;   
}
    bool isValid(string s) {
      return  helper(s);
    }
};
